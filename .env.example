# 是否开启深度思考模式 (True/False)
AGENT_INCLUDE_THINK=False

# 嵌入模型
EMBEDDING_MODEL_NAME=/root/.cache/modelscope/hub/models/BAAI/bge-m3

# --- 检索参数 (Retrieval Settings) ---
# 粗排阶段：从 FAISS 和 BM25 各自召回的数量
RETRIEVAL_TOP_K=20

# 精排阶段：Reranker 处理后最终给到 LLM 的片段数量
RERANK_TOP_N=10
RERANK_THRESHOLD=0.0

# RRF 融合常数 (通常为 60)
RRF_K=60

# --- 文档处理参数 (Indexing Settings) ---
# 每个知识切片的大小 (建议 800-1000)
CHUNK_SIZE=1000
# 切片重叠部分 (建议 150-200)
CHUNK_OVERLAP=200

# --- 模型开关 ---
INCLUDE_THINK=True

# rerank 模型路径
RERANKER_MODEL_PATH=/path/to/bge-reranker-v2-m3

# LangSmith 监控
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY="your-langsmith-api-key"
LANGCHAIN_PROJECT="Kortex"

# Redis 配置
REDIS_HOST=172.20.0.10
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=yourpassword

# Milvus 配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# --- LLM 配置 ---
# 单节点配置
LLM_BASE_URL=https://xiaoai.plus/v1
LLM_API_KEY=your-api-key
LLM_MODEL_NAME=gpt-4o-mini
LLM_MAX_CONCURRENT=2

# 多节点配置 (JSON 格式，优先于单节点配置)
# LLM_NODES_JSON=[
#   {"name":"Local-vLLM","url":"http://localhost:20201/v1","api_key":"token","model_name":"gpt-oss-20b","max_concurrent":8},
#   {"name":"Cloud-GPT4","url":"https://xiaoai.plus/v1","api_key":"sk-xxx","model_name":"gpt-4o-mini","max_concurrent":2}
# ]
